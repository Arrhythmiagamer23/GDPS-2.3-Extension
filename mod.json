{
	"geode": "5.6.1",
	"early-load": true,
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "roadhogstudios.reminafeatures",
	"name": "2point3 Features",
	"version": "v1.3.1",
	"developers": [ "lil2kki", "roadhogstudios" ],
	"description": "remina.bccst.ru",
	"links": {
		"source": "https://github.com/Arrhythmiagamer23/GDPS-2.3-Extension",
		"community": "https://discord.gg/NXbbv2HZGg",
		"homepage": "https://remina.bccst.ru"
	},
	"dependencies": {
		"geode.node-ids": {
			"version": ">=v1.20.0",
			"required": false
		},
		"prevter.imageplus": {
			"version": ">=v1.0.3",
			"required": false
		},
		"alphalaneous.happy_textures": {
			"version": ">=v2.0.7",
			"required": false
		}
	},
	"resources": {
		"sprites": [
			"assets/sprites/**/**/*.png"
		],
		"spritesheets": {
			"spritesheet": [
				"assets/frames/**/**/*.png"
			]
		}
	},
	"settings": {
		"redir request urls": {
			"name": "redir request urls",
			"description": "replace boomlings.com/database with the our server url in all requests",
			"type": "bool",
			"default": false
		},
		"leave labels alone you dumb bitch": {
			"name": "don't break labels you genius",
			"description": "she will see and stop breaking the labels. what is she even trying to say?",
			"type": "bool",
			"default": false
		},
		"past": {
			"name": "past",
			"description": "things was better then ya?",
			"type": "bool",
			"default": false
		}
	}
}
